PORT=8080
NODE_ENV=development
API_PREFIX=/api
# URL browsers use for API (Jupyter iframe proxy links). Example: http://your-server:8082/api
API_PUBLIC_URL=http://localhost:8082/api
CORS_ORIGIN=*

# JWT (required in production)
JWT_SECRET=your-strong-secret-min-32-chars
JWT_EXPIRES_IN=24h

# DynamoDB (matches vlab/terraform — leave empty for local in-memory)
SESSIONS_TABLE_NAME=vlab-sessions
RUNS_TABLE_NAME=vlab-runs
SUBMISSIONS_TABLE_NAME=lab-submissions
RESULTS_TABLE_NAME=lab-results

# ECS Fargate (leave ECS_CLUSTER empty for mock sessions)
AWS_REGION=ap-south-1
ECS_CLUSTER=vlab-dev-cluster
ECS_SUBNETS=subnet-xxx,subnet-yyy
ECS_SECURITY_GROUPS=sg-xxx

# public = this backend reaches ECS task through its public IP
# private = backend runs inside the VPC and reaches taskPrivateIp
CONTAINER_HOST_MODE=public
DEFAULT_SESSION_TIMEOUT=120

# false lets the local fallback run when the ECS public IP is unreachable.
FORCE_CONTAINER_EXECUTION=false

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ignito_experia
DB_USER=root
DB_PASSWORD=

# ──────────────────────────────────────────────
# Email / SMTP  (Nodemailer)
# ──────────────────────────────────────────────
# Gmail: enable 2FA on your Google account, then create an App Password at
#   https://myaccount.google.com/apppasswords
#   Use SMTP_PASS = the 16-character App Password (no spaces)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
SMTP_FROM_NAME=Ignito Experia
SMTP_FROM_EMAIL=your-gmail@gmail.com

# Frontend URL used in email links
FRONTEND_URL=http://localhost:5173
