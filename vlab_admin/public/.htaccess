# Ignito Experia — Apache config for Vite SPA + API proxy
# Deploy the contents of vlab_admin/dist to your Apache document root.
#
# Required Apache modules (Ubuntu/Debian):
#   sudo a2enmod rewrite proxy proxy_http proxy_wstunnel headers
#   sudo systemctl restart apache2
#
# When using this proxy, set env vars WITHOUT :8080:
#   API_PUBLIC_URL=http://13.232.218.15/api
#   VITE_API_BASE_URL=http://13.232.218.15/api

<IfModule mod_proxy.c>
  ProxyPreserveHost On
  ProxyRequests Off

  # REST API → Node backend
  ProxyPass        /api http://127.0.0.1:8080/api
  ProxyPassReverse /api http://127.0.0.1:8080/api

  # Socket.IO (terminal) — HTTP polling
  ProxyPass        /socket.io http://127.0.0.1:8080/socket.io
  ProxyPassReverse /socket.io http://127.0.0.1:8080/socket.io
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Socket.IO — WebSocket upgrade
  RewriteCond %{HTTP:Upgrade} =websocket [NC]
  RewriteRule ^socket\.io/(.*)$ ws://127.0.0.1:8080/socket.io/$1 [P,L]

  # SPA client-side routes (TanStack Router)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} !^/api
  RewriteCond %{REQUEST_URI} !^/socket\.io
  RewriteRule . /index.html [L]
</IfModule>

# Cache static assets; never cache index.html
<IfModule mod_headers.c>
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
  <FilesMatch "\.(js|css|png|jpg|jpeg|gif|svg|ico|woff|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
